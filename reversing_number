import java.util.Scanner;
class Main {
    public static void main(String[] args) {
        Scanner s=new Scanner(System.in);
        int a,rev=0;
        
        System.out.println("Give me a number sequence:");
        a=s.nextInt();
        
        while(a!=0)
        {
            int digit=a%10;
            rev=rev*10+digit;
            a=a/10;
        }
        System.out.println("Reversed Number is:"+rev);
        
    }
}
